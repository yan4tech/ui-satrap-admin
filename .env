# Server url — dev/release: leave empty for same-origin /api/* (Next rewrites or nginx)
# NEXT_PUBLIC_SERVER_URL=

# موتور فرایند — dev: خالی (proxy از Next) — release/nginx: http://127.0.0.1
# NEXT_PUBLIC_ENGINE_URL=

# Public resource directory
NEXT_PUBLIC_ASSETS_DIR=

# Mapbox
NEXT_PUBLIC_MAPBOX_API_KEY=

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APPID=

# Aws
NEXT_PUBLIC_AWS_AMPLIFY_USER_POOL_ID=
NEXT_PUBLIC_AWS_AMPLIFY_USER_POOL_WEB_CLIENT_ID=
NEXT_PUBLIC_AWS_AMPLIFY_REGION=


# Auth0
NEXT_PUBLIC_AUTH0_DOMAIN=
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_CALLBACK_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Traefik/release: http://127.0.0.1 — dev: خالی (proxy از Next)
# NEXT_PUBLIC_GATEWAY_URL=

# POS agent — dev: خالی (proxy از Next) — release: http://127.0.0.1:18800
# NEXT_PUBLIC_POS_AGENT_URL=
